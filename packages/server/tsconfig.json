{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "declaration": false,
    "noEmit": false,
    "paths": {
      "@oc/shared": ["../shared/src/index.ts"],
      "@oc/shared/*": ["../shared/src/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*.ts"]
}
