{
  "name": "openclaw-deploy",
  "version": "0.1.0",
  "private": true,
  "description": "zhangyangbin.com chat frontend + supporting services",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm run test:unit && npm run test:smoke && npm run test:e2e",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:smoke": "bash tests/smoke/smoke.sh",
    "test:smoke:remote": "bash tests/smoke/smoke.sh https://zhangyangbin.com",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "sync": "node scripts/sync-prod.mjs",
    "units:sync": "node scripts/sync-units.mjs",
    "units:reload": "node scripts/sync-units.mjs --reload",
    "deploy": "npm run test:unit && npm run sync && npm run test:smoke"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0"
  }
}
