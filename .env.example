# OpenClaw Deploy — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# Domain name for Nginx virtual host
DOMAIN=zhangyangbin.com

# OpenClaw gateway internal port (loopback only)
OPENCLAW_PORT=18789

# OpenClaw config directory
OPENCLAW_HOME=$HOME/.openclaw

# AI Provider API key (e.g. GitHub Copilot, OpenAI, Anthropic)
# OPENCLAW_PROVIDER_KEY=your-api-key-here
